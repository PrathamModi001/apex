# Postgres
POSTGRES_DB=apex
POSTGRES_USER=apex
POSTGRES_PASSWORD=your_postgres_password_here
DATABASE_URL=postgresql://apex:your_postgres_password_here@postgres:5432/apex

# Redis
REDIS_URL=redis://redis:6379

# Kafka
KAFKA_BROKERS=redpanda:29092

# Neo4j
NEO4J_AUTH=neo4j/your_neo4j_password_here
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# MinIO
MINIO_ROOT_USER=apex_minio
MINIO_ROOT_PASSWORD=your_minio_password_here
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=invoices

# LLM
GROQ_API_KEY=your_groq_api_key_here

# Auth (use JWT_SECRET for local dev, or RSA keys for production — see docs/CREDENTIALS.md)
JWT_SECRET=change_me_in_production
# JWT_PRIVATE_KEY=<base64-encoded-private-pem>
# JWT_PUBLIC_KEY=<base64-encoded-public-pem>

# Gmail OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# Service URLs
AGENT_SERVICE_URL=http://agent-service:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_AGENT_SERVICE_URL=http://localhost:8000
